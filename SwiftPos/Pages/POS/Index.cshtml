@page
@model SwiftPOS.Pages.POS.IndexModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "POS Terminal";
    var token = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken;
}

<input type="hidden" id="antiforgeryToken" value="@token">

<div class="container-fluid pf-container">
    <div class="row vh-100 overflow-hidden">

        <div class="col-md-8 bg-light d-flex flex-column p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold text-dark m-0">Billing Terminal</h4>

                <div class="category-wrapper">
                    <button class="cat-pill active" onclick="filterCategory('All', this)">All Items</button>
                    <button class="cat-pill" onclick="filterCategory('Food', this)">Food</button>
                    <button class="cat-pill" onclick="filterCategory('Electronic', this)">Electronic</button>
                    <button class="cat-pill" onclick="filterCategory('Grocery', this)">Grocery</button>
                </div>
            </div>

            <div class="row g-3 flex-grow-1 overflow-auto pe-1" id="pList">
                @foreach (var p in Model.Products)
                {
                    <div class="col-md-3 pos-item" data-category="@p.Category">
                        <div class="product-card @(p.StockQuantity <= 0 ? "out-of-stock" : "")"
                             onclick="@(p.StockQuantity > 0 ? $"addToCart('{p.Id}', '{p.Name}', {p.Price}, {p.StockQuantity})" : "")">

                            <div class="icon-box">
                                <i class="bi @(p.StockQuantity <= 0 ? "bi-exclamation-triangle text-danger" : "bi-box-seam")"></i>
                            </div>

                            <h6 class="product-name">@p.Name</h6>
                            <span class="product-price">$@p.Price.ToString("N2")</span>

                            <div class="mt-2">
                                @if (p.StockQuantity <= 0)
                                {
                                    <span class="badge bg-danger rounded-pill small">Sold Out</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted border rounded-pill small">Stock: @p.StockQuantity</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-4 bg-white shadow-lg d-flex flex-column p-4 cart-sidebar">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h5 class="fw-bold m-0 text-dark">Current Order</h5>
                <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">LIVE</span>
            </div>

            <div class="mb-3">
                <label class="small fw-bold text-muted mb-1">Customer Info</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-person"></i></span>
                    <input type="text" id="custName" class="form-control bg-light border-0 shadow-none" placeholder="Guest Customer">
                </div>
            </div>

            <div id="cartItems" class="flex-grow-1 overflow-auto cart-items-list mb-3">
                <div class="text-center text-muted mt-5 empty-msg">
                    <i class="bi bi-cart3 display-4 d-block mb-3 opacity-25"></i>
                    <p class="small">Click on cards to add items</p>
                </div>
            </div>

            <div class="order-summary-box pt-3 border-top">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Total Items</span>
                    <span class="fw-bold" id="itemCount">0</span>
                </div>
                <div class="d-flex justify-content-between h3 fw-bold text-dark mb-4 mt-2">
                    <span>Total</span>
                    <span id="grandTotal" style="color: #005f73;">$0.00</span>
                </div>

                <button class="btn btn-dark w-100 btn-checkout py-3 fw-bold rounded-4 shadow-sm" id="btnPlaceOrder" onclick="checkout()">
                    <i class="bi bi-credit-card-2-back me-2"></i> COMPLETE BILLING
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-teal: #005f73;
        --accent-orange: #fb8500;
        --light-bg: #f4f7f6;
    }

    /* Grid ko tight karne ke liye minmax 140px kiya */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(145px, 1fr));
        gap: 12px; /* Gaps mazeed kam */
        padding: 10px;
    }

    /* Card ka size chota aur compact */
    .product-card {
        background: white;
        border-radius: 16px; /* Slightly less rounded for smaller size */
        padding: 12px; /* Reduced padding */
        text-align: center;
        transition: all 0.3s ease;
        border: 1px solid rgba(0,0,0,0.03);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.04);
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 300px; /* Fixed height taaki alignment kharab na ho */
    }

        .product-card:hover:not(.out-of-stock) {
            transform: translateY(-5px);
            box-shadow: 0 12px 20px rgba(0, 0, 0, 0.08);
            border-color: var(--primary-teal);
        }

    /* Icon box ko aur chota kiya */
    .icon-box {
        width: 40px;
        height: 40px;
        background: #f0f9fa;
        color: var(--primary-teal);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 8px;
        font-size: 1.2rem;
    }

    /* Text size chota kiya taaki box chota lagay */
    .product-name {
        font-size: 1.0rem;
        font-weight: 800;
        color: #334155;
        margin-bottom: 4px;
        line-height: 1.2;
        height: 2rem; /* Max 2 lines */
        overflow: hidden;
    }

    .product-price {
        color: var(--primary-teal);
        font-weight: 800;
        font-size: 0.9rem;
        margin-bottom: 5px;
    }

    .stock-badge {
        font-size: 0.65rem;
        background: #f8fafc;
        color: #64748b;
        padding: 2px 8px;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
    }

    /* Sold Out Ribbon - mazeed compact */
    .out-of-stock::after {
        content: "SOLD OUT";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        background: rgba(239, 68, 68, 0.85);
        color: white;
        font-size: 0.6rem;
        font-weight: 800;
        padding: 2px 0;
        border-radius: 16px 16px 0 0; /* Card ke top par fix */
    }

    .out-of-stock {
        opacity: 0.6;
        filter: grayscale(1);
    }

    /* Sidebar buttons aur search field ko bhi compact rakhein */
    .btn-checkout {
        padding: 10px;
        font-size: 0.9rem;
        border-radius: 12px;
    }
</style>

@section Scripts {
    <script>
        let cart = [];
        let total = 0;

        function addToCart(id, name, price, stock) {
            const existingItem = cart.find(i => i.id === id);

            if (existingItem) {
                // Check agar cart mein quantity stock se zyada na ho jaye
                if (existingItem.qty >= stock) {
                    alert("Bas bhai! Itna hi stock bacha hai.");
                    return;
                }
                existingItem.qty++;
            } else {
                cart.push({ id, name, price, qty: 1, maxStock: stock });
            }
            updateCartUI();
        }

        function updateCartUI() {
            const container = document.getElementById('cartItems');
            const totalItemsLabel = document.getElementById('itemCount');
            const grandTotalLabel = document.getElementById('grandTotal');

            if (cart.length === 0) {
                container.innerHTML = `<div class="text-center text-muted mt-5 empty-msg"><i class="bi bi-cart3 display-4 d-block mb-3 opacity-25"></i><p class="small">Click on cards to add items</p></div>`;
                totalItemsLabel.innerText = "0";
                grandTotalLabel.innerText = "$0.00";
                total = 0;
                return;
            }

            container.innerHTML = '';
            total = 0;
            let totalQty = 0;

            cart.forEach((item, index) => {
                total += (item.price * item.qty);
                totalQty += item.qty;
                container.innerHTML += `
                            <div class="cart-item d-flex justify-content-between align-items-center">
                                <div style="flex: 1;">
                                    <h6 class="mb-0 fw-bold small">${item.name}</h6>
                                    <small class="text-muted">$${item.price.toFixed(2)} x ${item.qty}</small>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold text-dark mb-1 small">$${(item.price * item.qty).toFixed(2)}</div>
                                    <button class="btn btn-sm text-danger p-0 border-0" onclick="removeItem(${index})"><i class="bi bi-trash"></i></button>
                                </div>
                            </div>`;
            });

            totalItemsLabel.innerText = totalQty;
            grandTotalLabel.innerText = `$${total.toFixed(2)}`;
        }

        function removeItem(index) {
            cart.splice(index, 1);
            updateCartUI();
        }

        function filterCategory(cat, btn) {
            document.querySelectorAll('.cat-pill').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            document.querySelectorAll('.pos-item').forEach(item => {
                item.style.display = (cat === 'All' || item.getAttribute('data-category') === cat) ? 'block' : 'none';
            });
        }

        async function checkout() {
            if (cart.length === 0) return alert("Cart khali hai!");

            const btn = document.getElementById('btnPlaceOrder');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing...';

            const orderData = {
                customerName: document.getElementById('custName').value || "Guest Customer",
                grandTotal: parseFloat(total),
                orderDate: new Date().toISOString(),
                items: cart.map(i => ({
                    productId: i.id,
                    productName: i.name,
                    quantity: i.qty,
                    unitPrice: i.price
                }))
            };

            try {
                const response = await fetch('/POS/Index?handler=ProcessSale', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.getElementById('antiforgeryToken').value
                    },
                    body: JSON.stringify(orderData)
                });

                const res = await response.json();
                if (res.success) {
                    // Success ke baad Sales History par bhej dein
                    window.location.href = "/SalesHistory";
                } else {
                    alert("Error: " + res.message);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-credit-card-2-back me-2"></i> COMPLETE BILLING';
                }
            } catch (err) {
                alert("Server Error!");
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-credit-card-2-back me-2"></i> COMPLETE BILLING';
            }
        }
    </script>
}