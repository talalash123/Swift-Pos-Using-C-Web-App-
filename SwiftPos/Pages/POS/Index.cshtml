@page
@model SwiftPOS.Pages.POS.IndexModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "POS Terminal";
    var token = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken;
}

<input type="hidden" id="antiforgeryToken" value="@token">

<div class="container-fluid pf-container bg-light">
    <div class="row vh-100 overflow-hidden">

        <div class="col-md-8 d-flex flex-column p-4">
            <div class="d-flex justify-content-between align-items-end mb-4">
                <div>
                    <h4 class="fw-bold text-dark m-0">Billing Terminal</h4>
                    <small class="text-muted">Select products to add to order</small>
                </div>

                <div class="category-wrapper d-flex gap-2">
                    <button class="cat-pill active" onclick="filterCategory('All', this)">All</button>
                    <button class="cat-pill" onclick="filterCategory('Food', this)">Food</button>
                    <button class="cat-pill" onclick="filterCategory('Electronic', this)">Electronics</button>
                    <button class="cat-pill" onclick="filterCategory('Grocery', this)">Grocery</button>
                </div>
            </div>

            <div class="row g-3 overflow-auto flex-grow-1 pt-2" id="pList" style="align-content: start;">
                @foreach (var p in Model.Products)
                {
                    <div class="col-xl-3 col-lg-4 col-md-6 pos-item" data-category="@p.Category">
                        <div class="product-card @(p.StockQuantity <= 0 ? "out-of-stock" : "")"
                             onclick="@(p.StockQuantity > 0 ? $"addToCart('{p.Id}', '{p.Name}', {p.Price}, {p.StockQuantity})" : "")">

                            <div class="icon-box">
                                <i class="bi @(p.StockQuantity <= 0 ? "bi-exclamation-octagon text-danger" : "bi-box-seam")"></i>
                            </div>

                            <div class="product-info mt-2">
                                <h6 class="product-name">@p.Name</h6>
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <span class="product-price">$@p.Price.ToString("N2")</span>
                                    @if (p.StockQuantity <= 0)
                                    {
                                        <span class="badge bg-danger-subtle text-danger border-0">Sold Out</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border small">Qty: @p.StockQuantity</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-4 bg-white shadow-sm d-flex flex-column p-4 cart-sidebar border-start">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                <h5 class="fw-bold m-0 text-dark"><i class="bi bi-receipt me-2"></i>Current Order</h5>
                <span class="badge bg-success-subtle text-success rounded-pill px-3">Active</span>
            </div>

            <div class="mb-4">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-person"></i></span>
                    <input type="text" id="custName" class="form-control border-start-0 ps-0 shadow-none" placeholder="Customer Name (Optional)">
                </div>
            </div>

            <div id="cartItems" class="flex-grow-1 overflow-auto mb-3 pe-2">
                <div class="text-center text-muted mt-5 empty-msg">
                    <i class="bi bi-cart3 display-1 d-block mb-3 opacity-10"></i>
                    <p class="fw-medium">Your cart is empty</p>
                </div>
            </div>

            <div class="order-summary-box pt-3 border-top bg-light p-3 rounded-4">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Items Count:</span>
                    <span class="fw-bold small" id="itemCount">0</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Subtotal:</span>
                    <span class="fw-bold small" id="subtotalAmount">$0.00</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Tax (5%):</span>
                    <span class="text-primary fw-bold small" id="taxAmount">$0.00</span>
                </div>

                <hr class="my-2" style="border-top: 1px dashed #cbd5e1;">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <span class="h5 fw-bold m-0 text-dark">Grand Total</span>
                    <span class="h3 fw-bold m-0" id="grandTotal" style="color: #005f73;">$0.00</span>
                </div>

                <button class="btn btn-dark w-100 btn-checkout py-3 fw-bold rounded-3 shadow-sm" id="btnPlaceOrder" onclick="checkout()">
                    <i class="bi bi-check-circle-fill me-2"></i> COMPLETE BILLING
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="receiptModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-body p-4" id="printArea">
                <div class="text-center mb-3">
                    <h5 class="fw-bold mb-0">SWIFTPOS</h5>
                    <small class="text-muted">Digital Receipt</small>
                    <hr class="my-2" style="border-top: 1px dashed #000;">
                </div>

                <div class="mb-3 small">
                    <div class="d-flex justify-content-between">
                        <span>Date:</span> <span id="rDate"></span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Customer:</span> <span id="rCustName"></span>
                    </div>
                </div>

                <table class="table table-sm table-borderless small mb-0">
                    <thead>
                        <tr class="border-bottom">
                            <th>Item</th>
                            <th class="text-center">Qty</th>
                            <th class="text-end">Price</th>
                        </tr>
                    </thead>
                    <tbody id="rItemsBody">
                    </tbody>
                </table>

                <hr class="my-2" style="border-top: 1px dashed #000;">

                <div class="small">
                    <div class="d-flex justify-content-between">
                        <span>Subtotal:</span> <span id="rSubtotal"></span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Tax (5%):</span> <span id="rTax"></span>
                    </div>
                    <div class="d-flex justify-content-between fw-bold mt-2 pt-2 border-top h6">
                        <span>GRAND TOTAL:</span> <span id="rTotal"></span>
                    </div>
                </div>

                <div class="text-center mt-4 pt-2">
                    <p class="small mb-0">*** Thank You! ***</p>
                </div>
            </div>
            <div class="modal-footer border-0 p-3 bg-light">
                <button type="button" class="btn btn-outline-secondary w-100" onclick="window.location.reload()">Close & New Order</button>
                <button type="button" class="btn btn-dark w-100" onclick="printReceipt()">
                    <i class="bi bi-printer me-2"></i>Print Receipt
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-teal: #005f73;
        --accent-teal: #0a9396;
        --sidebar-bg: #ffffff;
        --app-bg: #f8fafb;
        --card-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    }

    /* Full Page Layout Reset */
    .pf-container {
        background-color: var(--app-bg) !important;
        height: 100vh;
    }

    /* Category Navigation - Pill Style */
    .category-wrapper {
        background: #f1f5f9;
        padding: 5px;
        border-radius: 12px;
    }

    .cat-pill {
        border: none;
        background: transparent;
        padding: 8px 18px;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        color: #64748b;
        transition: 0.2s all;
    }

        .cat-pill.active {
            background: white;
            color: var(--primary-teal);
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }

    /* Modern Product Card */
    .product-card {
        background: white;
        border: 1px solid rgba(226, 232, 240, 0.6);
        border-radius: 16px;
        padding: 16px;
        transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        position: relative;
    }

        .product-card:hover:not(.out-of-stock) {
            border-color: var(--accent-teal);
            box-shadow: 0 10px 20px rgba(0,0,0,0.04);
            transform: translateY(-4px);
        }

    .icon-box {
        width: 42px;
        height: 42px;
        background: #f0f9fa;
        color: var(--primary-teal);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }

    .product-name {
        font-size: 0.9rem;
        font-weight: 700;
        color: #1e293b;
        margin-top: 12px;
        line-height: 1.2;
    }

    .product-price {
        color: var(--primary-teal);
        font-weight: 800;
        font-size: 1rem;
        letter-spacing: -0.5px;
    }

    /* Cart Sidebar & Items */
    .cart-sidebar {
        background-color: white !important;
        border-left: 1px solid #e2e8f0;
    }

    .cart-item {
        display: flex;
        align-items: center;
        padding: 12px;
        background: white;
        border-radius: 12px;
        margin-bottom: 10px;
        border: 1px solid #f1f5f9;
        transition: 0.2s;
    }

        .cart-item:hover {
            border-color: #cbd5e1;
        }

    /* Order Summary Area */
    .order-summary-box {
        background: #f8fafc !important;
        border: 1px solid #e2e8f0;
        padding: 20px !important;
        border-radius: 16px !important;
    }

    #grandTotal {
        color: var(--primary-teal);
        letter-spacing: -1px;
    }

    /* Checkout Button */
    .btn-checkout {
        background: var(--primary-teal) !important;
        border: none;
        padding: 14px !important;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
    }

        .btn-checkout:hover {
            background: #004654 !important;
            box-shadow: 0 4px 15px rgba(0, 95, 115, 0.3);
        }

    /* Minimal Scrollbar */
    ::-webkit-scrollbar {
        width: 5px;
    }

    ::-webkit-scrollbar-track {
        background: transparent;
    }

    ::-webkit-scrollbar-thumb {
        background: #e2e8f0;
        border-radius: 10px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: #cbd5e1;
        }
</style>
@section Scripts {
    <script>
        let cart = [];
        let subtotal = 0;
        let taxRate = 0.05; // 5% Tax

        function addToCart(id, name, price, stock) {
            const existingItem = cart.find(i => i.id === id);

            if (existingItem) {
                if (existingItem.qty >= stock) {
                    alert("Bas bhai! Itna hi stock bacha hai.");
                    return;
                }
                existingItem.qty++;
            } else {
                cart.push({ id, name, price, qty: 1, maxStock: stock });
            }
            updateCartUI();
        }

        function updateCartUI() {
            const container = document.getElementById('cartItems');
            const totalItemsLabel = document.getElementById('itemCount');

            // In IDs ko apne HTML mein check kar lein ya add kar lein
            const subtotalLabel = document.getElementById('subtotalAmount');
            const taxLabel = document.getElementById('taxAmount');
            const grandTotalLabel = document.getElementById('grandTotal');

            if (cart.length === 0) {
                container.innerHTML = `<div class="text-center text-muted mt-5 empty-msg"><i class="bi bi-cart3 display-4 d-block mb-3 opacity-25"></i><p class="small">Click on cards to add items</p></div>`;
                totalItemsLabel.innerText = "0";
                if (subtotalLabel) subtotalLabel.innerText = "$0.00";
                if (taxLabel) taxLabel.innerText = "$0.00";
                grandTotalLabel.innerText = "$0.00";
                subtotal = 0;
                return;
            }

            container.innerHTML = '';
            subtotal = 0;
            let totalQty = 0;

            cart.forEach((item, index) => {
                subtotal += (item.price * item.qty);
                totalQty += item.qty;
                container.innerHTML += `
                            <div class="cart-item d-flex justify-content-between align-items-center p-2 mb-2 bg-light rounded shadow-sm">
                                <div style="flex: 1;">
                                    <h6 class="mb-0 fw-bold small">${item.name}</h6>
                                    <small class="text-muted">$${item.price.toFixed(2)} x ${item.qty}</small>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold text-dark mb-1 small">$${(item.price * item.qty).toFixed(2)}</div>
                                    <button class="btn btn-sm text-danger p-0 border-0" onclick="removeItem(${index})"><i class="bi bi-trash"></i></button>
                                </div>
                            </div>`;
            });

            // --- Tax Calculation Logic ---
            let taxTotal = subtotal * taxRate;
            let finalGrandTotal = subtotal + taxTotal;

            totalItemsLabel.innerText = totalQty;

            // UI Updates
            if (subtotalLabel) subtotalLabel.innerText = `$${subtotal.toFixed(2)}`;
            if (taxLabel) taxLabel.innerText = `$${taxTotal.toFixed(2)}`;
            grandTotalLabel.innerText = `$${finalGrandTotal.toFixed(2)}`;
        }

        function removeItem(index) {
            cart.splice(index, 1);
            updateCartUI();
        }

        function filterCategory(cat, btn) {
            document.querySelectorAll('.cat-pill').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            document.querySelectorAll('.pos-item').forEach(item => {
                item.style.display = (cat === 'All' || item.getAttribute('data-category') === cat) ? 'block' : 'none';
            });
        }

        async function checkout() {
            if (cart.length === 0) return alert("Cart is empty!");

            const btn = document.getElementById('btnPlaceOrder');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing...';

            let currentSubtotal = cart.reduce((sum, i) => sum + (i.price * i.qty), 0);
            let currentTax = currentSubtotal * taxRate;
            let currentGrandTotal = currentSubtotal + currentTax;

            const orderData = {
                customerName: document.getElementById('custName').value || "Guest Customer",
                grandTotal: parseFloat(currentGrandTotal.toFixed(2)),
                orderDate: new Date().toISOString(),
                items: cart.map(i => ({
                    productId: i.id,
                    productName: i.name,
                    quantity: i.qty,
                    unitPrice: i.price
                }))
            };

            try {
                const response = await fetch('/POS/Index?handler=ProcessSale', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.getElementById('antiforgeryToken').value
                    },
                    body: JSON.stringify(orderData)
                });

                const res = await response.json();
                if (res.success) {
                    // --- Receipt Modal Fill Logic ---
                    document.getElementById('rDate').innerText = new Date().toLocaleString();
                    document.getElementById('rCustName').innerText = orderData.customerName;
                    document.getElementById('rSubtotal').innerText = `$${currentSubtotal.toFixed(2)}`;
                    document.getElementById('rTax').innerText = `$${currentTax.toFixed(2)}`;
                    document.getElementById('rTotal').innerText = `$${currentGrandTotal.toFixed(2)}`;

                    let itemsHtml = '';
                    cart.forEach(i => {
                        itemsHtml += `<tr>
                            <td>${i.name}</td>
                            <td class="text-center">${i.qty}</td>
                            <td class="text-end">$${(i.price * i.qty).toFixed(2)}</td>
                        </tr>`;
                    });
                    document.getElementById('rItemsBody').innerHTML = itemsHtml;

                    // Show Modal
                    const receiptModal = new bootstrap.Modal(document.getElementById('receiptModal'));
                    receiptModal.show();
                } else {
                    alert("Error: " + res.message);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i> COMPLETE BILLING';
                }
            } catch (err) {
                alert("Server Error!");
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i> COMPLETE BILLING';
            }
        }

        // Print Function
        function printReceipt() {
            const printContent = document.getElementById('printArea').innerHTML;
            const originalContent = document.body.innerHTML;
            document.body.innerHTML = printContent;
            window.print();
            document.body.innerHTML = originalContent;
            window.location.reload(); // Reset everything after print
        } 
    </script>
}