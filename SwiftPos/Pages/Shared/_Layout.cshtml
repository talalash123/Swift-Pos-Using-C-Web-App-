<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SwiftPOS - Main Terminal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --sidebar-bg: #ffffff;
            --primary-color: #005f73;
            --active-bg: #e6f7f8;
            --text-muted: #94a3b8;
            --text-dark: #1e293b;
            --sidebar-shadow: 10px 0 30px rgba(0,0,0,0.02);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f1f5f9;
            margin: 0;
        }

        /* --- MODERN SIDEBAR --- */
        .sidebar {
            width: 280px;
            height: 100vh;
            background: var(--sidebar-bg);
            border-right: 1px solid #e2e8f0; /* Dashed ki jagah solid thora zyada professional lagta hai */
            position: fixed;
            padding: 24px 16px;
            display: flex;
            flex-direction: column;
            box-shadow: var(--sidebar-shadow);
            z-index: 1000;
        }

        /* Logo Area */
        .brand-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0 12px 30px;
        }

        .logo-box {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--primary-color) 0%, #0a9396 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.3rem;
            box-shadow: 0 4px 10px rgba(0, 95, 115, 0.2);
        }

        /* Nav Links */
        .nav-label {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 800;
            color: var(--text-muted);
            margin: 20px 12px 10px;
        }

        .nav-link {
            color: #64748b;
            font-weight: 600;
            font-size: 0.95rem;
            padding: 12px 16px;
            border-radius: 12px;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            text-decoration: none !important;
        }

            /* Icon Fix: Is se icon aur text bilkul align rahenge */
            .nav-link i {
                font-size: 1.2rem;
                width: 28px; /* Fixed width taaki text ek hi vertical line mein ho */
                display: flex;
                align-items: center;
                justify-content: flex-start;
                transition: 0.3s;
            }

            /* Active & Hover States */
            .nav-link:hover {
                background: #f8fafc;
                color: var(--primary-color);
                transform: translateX(5px);
            }

            .nav-link.active {
                background: var(--active-bg);
                color: var(--primary-color);
                position: relative;
            }

                /* Active Dot Indicator */
                .nav-link.active::after {
                    content: '';
                    position: absolute;
                    right: 15px;
                    width: 6px;
                    height: 6px;
                    background: var(--primary-color);
                    border-radius: 50%;
                    box-shadow: 0 0 8px var(--primary-color);
                }

                .nav-link.active i {
                    transform: scale(1.1);
                    color: var(--primary-color);
                }

        /* Main Content */
        .main-content {
            margin-left: 280px;
            padding: 40px;
            min-height: 100vh;
        }

        /* Footer Section */
        .sidebar-footer {
            margin-top: auto;
            background: #f8fafc;
            padding: 14px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            border: 1px solid #f1f5f9;
        }

        .avatar {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--primary-color);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="brand-logo">
            <div class="logo-box">
                <i class="bi bi-lightning-charge-fill"></i>
            </div>
            <h4 class="fw-bold m-0" style="color: var(--text-dark); letter-spacing: -1px;">SwiftPOS</h4>
        </div>

        <div class="nav-label">Main Menu</div>
        <nav class="nav flex-column">
            <a href="/Dashboard" class="nav-link active">
                <i class="bi bi-grid-1x2-fill"></i>
                <span>Dashboard</span>
            </a>

            <a href="/POS/Index" class="nav-link">
                <i class="bi bi-calculator-fill"></i>
                <span>POS Terminal</span>
            </a>
        </nav>

        <div class="nav-label">Management</div>
        <nav class="nav flex-column">
            <a href="/Inventory/Index" class="nav-link">
                <i class="bi bi-box-seam-fill"></i>
                <span>Inventory</span>
            </a>
            <a href="/SalesHistory" class="nav-link">
                <i class="bi bi-receipt-cutoff"></i>
                <span>Sales History</span>
            </a>
            <a href="/Settings" class="nav-link">
                <i class="bi bi-gear-fill"></i>
                <span>Settings</span>
            </a>
        </nav>

    </aside>

    <main class="main-content">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Auto-active link logic based on URL
        $(document).ready(function () {
            var current = window.location.pathname;
            $('.nav-link').each(function () {
                var $this = $(this);
                if ($this.attr('href') === current) {
                    $('.nav-link').removeClass('active');
                    $this.addClass('active');
                }
            });
        });
    </script>
</body>
</html>