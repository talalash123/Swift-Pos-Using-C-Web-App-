<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SwiftPOS - Kinetic</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fc;
            margin: 0;
        }

        .sidebar {
            width: 260px;
            height: 100vh;
            background: white;
            border-right: 1px solid #e3e6f0;
            position: fixed;
            padding: 20px;
        }

        .main-content {
            margin-left: 260px;
            padding: 30px;
        }

        .nav-link {
            color: #858796;
            font-weight: 600;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            text-decoration: none;
        }

            .nav-link:hover, .nav-link.active {
                background: #f0f4f8;
                color: #005f73;
            }

            .nav-link i {
                margin-right: 12px;
                font-size: 1.2rem;
            }
    </style>
</head>
<body>
    <div class="sidebar">
        <h4 class="fw-bold mb-4" style="color: #005f73;">SwiftPOS</h4>
        <nav>
            <a href="/Dashboard" class="nav-link active"><i class="bi bi-grid-fill"></i> Dashboard</a>
            <a href="/POS/Index" class="nav-link"><i class="bi bi-calculator"></i> Billing</a>
            <a href="/Inventory/Index" class="nav-link"><i class="bi bi-box-seam"></i> Inventory</a>
            <a href="/SalesHistory" class="nav-link"><i class="bi bi-clock-history"></i> Sales History</a>
        </nav>
    </div>nav>
    </div>
    <div class="main-content">
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>