@page
@model SwiftPOS.Pages.SalesHistoryModel
@{
    ViewData["Title"] = "Sales History";
}

<div class="container-fluid px-4 py-4 min-vh-100 main-container" style="background-color: #f8fafc;">
    <div class="d-flex justify-content-between align-items-center mb-4 no-print">
        <div>
            <h3 class="fw-bold text-dark mb-0">Sales History</h3>
            <p class="text-muted small">Comprehensive log of all store transactions</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/POS" class="btn btn-dark btn-sm rounded-pill px-4 shadow-sm" style="background-color: #004654; border: none;">
                <i class="bi bi-plus-lg me-1"></i> New Transaction
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4 no-print">
        <div class="col-md-6">
            <label class="small fw-bold text-muted text-uppercase mb-1">Quick Search</label>
            <div class="input-group shadow-sm rounded-3 overflow-hidden border-0">
                <span class="input-group-text border-0 bg-white pe-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="salesSearch" class="form-control border-0 py-2 ps-3"
                       placeholder="Search Transaction ID or Customer..."
                       onkeyup="filterSalesTable()">
            </div>
        </div>
        <div class="col-md-3">
            <label class="small fw-bold text-muted text-uppercase mb-1">Date Range</label>
            <select id="dateFilter" class="form-select border-0 shadow-sm rounded-3 py-2 small fw-semibold" onchange="filterSalesTable()">
                <option value="all">All Time</option>
                <option value="7">Last 7 Days</option>
                <option value="30">Last 30 Days</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="small fw-bold text-muted text-uppercase mb-1">Status</label>
            <select id="statusFilter" class="form-select border-0 shadow-sm rounded-3 py-2 small fw-semibold" onchange="filterSalesTable()">
                <option value="all">All Statuses</option>
                <option value="completed">Completed</option>
                <option value="pending">Pending</option>
                <option value="cancelled">Cancelled</option>
            </select>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5 printable-table">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="salesTable">
                <thead class="text-muted small text-uppercase fw-bold" style="background-color: #f1f5f9;">
                    <tr>
                        <th class="px-4 py-3 border-0">Transaction ID</th>
                        <th class="py-3 border-0">Date & Time</th>
                        <th class="py-3 border-0">Customer</th>
                        <th class="py-3 border-0">Total Amount</th>
                        <th class="py-3 border-0">Status</th>
                        <th class="px-4 py-3 text-end border-0 no-print">Action</th>
                    </tr>
                </thead>
                <tbody class="bg-white">
                    @foreach (var order in Model.Orders)
                    {
                        <tr class="sales-row border-bottom">
                            <td class="px-4 trx-id">
                                <span class="fw-bold px-2 py-1 rounded bg-light text-primary small" style="font-family: monospace;">
                                    #TRX-@(order.Id?.Substring(Math.Max(0, order.Id.Length - 8)))
                                </span>
                            </td>
                            <td class="order-date-cell">
                                <div class="fw-bold small text-dark">@order.OrderDate.ToString("MMM dd, yyyy")</div>
                                <div class="text-muted smaller">@order.OrderDate.ToString("hh:mm tt")</div>
                            </td>
                            <td class="cust-name">
                                <span class="small fw-semibold text-dark">@order.CustomerName</span>
                            </td>
                            <td class="amount-cell"><span class="fw-bold text-dark">$@order.GrandTotal.ToString("N2")</span></td>
                            <td class="status-cell">
                                <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill fw-bold" style="font-size: 0.65rem;">
                                    COMPLETED
                                </span>
                            </td>
                            <td class="px-4 text-end no-print">
                                <button class="btn btn-sm btn-light border rounded-circle shadow-sm" onclick="window.print()">
                                    <i class="bi bi-printer"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="row g-4 no-print">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 text-white overflow-hidden"
                 style="background: linear-gradient(135deg, #004654 0%, #002d36 100%);">
                <div class="card-body p-4">
                    <p class="small text-uppercase fw-bold opacity-75 mb-1">Total Period Revenue</p>
                    <h1 class="display-4 fw-bold mb-1" id="totalRevenueDisplay">$@Model.TotalPeriodRevenue.ToString("N2")</h1>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 p-4">
                <h6 class="fw-bold text-dark mb-4">Report Summary</h6>
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted small">Transactions Found:</span>
                    <span class="fw-bold text-dark" id="orderCount">@Model.Orders.Count</span>
                </div>
                <button class="btn btn-dark rounded-pill fw-bold py-2 w-100" onclick="window.print()" style="background-color: #004654; border:none;">
                    <i class="bi bi-printer me-2"></i> Print Table
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .smaller {
        font-size: 0.72rem;
    }

    .text-primary {
        color: #004654 !important;
    }

    .sales-row:hover {
        background-color: #f8fafc !important;
    }

    /* --- STRICT PRINT LOGIC --- */
    @@media print {
        /* 1. Hide every single thing by default */
        body * {
            visibility: hidden;
            box-shadow: none !important;
        }
        /* 2. Only show the table section and its children */
        .printable-table, .printable-table * {
            visibility: visible;
        }
        /* 3. Position the table at the very top of the printed page */
        .printable-table {
            position: absolute;
            left: 0;
            top: 0;
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
        }
        /* 4. Force hide 'Action' column and other no-print items even inside table */
        .no-print, .no-print * {
            display: none !important;
            visibility: hidden !important;
        }
        /* 5. Clean up table borders for paper */
        table {
            width: 100% !important;
            border: 1px solid #000 !important;
        }

        th, td {
            border: 1px solid #ddd !important;
            color: #000 !important;
        }
        /* Remove background gradients/colors for clear printing */
        .card, .bg-white {
            background-color: white !important;
        }
    }
</style>

@section Scripts {
    <script>
        function filterSalesTable() {
            let searchText = document.getElementById('salesSearch').value.toLowerCase();
            let dateRange = document.getElementById('dateFilter').value;
            let statusFilter = document.getElementById('statusFilter').value.toLowerCase();
            let rows = document.querySelectorAll('.sales-row');
            let count = 0;
            let totalRevenue = 0;

            rows.forEach(row => {
                let id = row.querySelector('.trx-id').innerText.toLowerCase();
                let name = row.querySelector('.cust-name').innerText.toLowerCase();
                let statusText = row.querySelector('.status-cell').innerText.toLowerCase();
                let amount = parseFloat(row.querySelector('.amount-cell').innerText.replace(/[$,]/g, '')) || 0;

                let orderDate = new Date(row.querySelector('.order-date-cell .fw-bold').innerText);
                let diffDays = Math.ceil((new Date() - orderDate) / (1000 * 60 * 60 * 24));

                let matchesSearch = id.includes(searchText) || name.includes(searchText);
                let matchesStatus = (statusFilter === "all") || statusText.includes(statusFilter);
                let matchesDate = (dateRange === "all") || (diffDays <= parseInt(dateRange));

                if (matchesSearch && matchesStatus && matchesDate) {
                    row.style.display = "";
                    count++;
                    totalRevenue += amount;
                } else {
                    row.style.display = "none";
                }
            });

            document.getElementById('orderCount').innerText = count;
            document.getElementById('totalRevenueDisplay').innerText = '$' + totalRevenue.toLocaleString(undefined, { minimumFractionDigits: 2 });
        }
    </script>
}