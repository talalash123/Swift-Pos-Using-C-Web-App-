@page
@using SwiftPOS.Models
@model SwiftPOS.Pages.Inventory.IndexModel
<div class="card border-0 shadow-sm p-4">
    <div class="d-flex justify-content-between mb-4">
        <div>
            <h3 class="fw-bold">Inventory Ledger</h3>
            <p class="text-muted">Manage your stock levels with precision.</p>
        </div>
        <a asp-page="./Create" class="btn btn-primary">+ Add New Product</a>
    </div>

    <table class="table table-borderless align-middle">
        <thead class="text-muted small border-bottom">
            <tr>
                <th>PRODUCT NAME</th><th>CATEGORY</th><th>PRICE</th><th>QUANTITY</th><th>STATUS</th><th>ACTIONS</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Products)
            {
                    <tr class="border-bottom">
                        <td><div class="fw-bold">@p.Name</div></td>
                        <td><span class="badge bg-light text-dark">@p.Category</span></td>
                        <td>$@p.Price</td>
                        <td>@(p is PhysicalProduct ph ? ph.StockQuantity : 0) units</td>
                        <td>
                        @if (p is PhysicalProduct ph2 && ph2.StockQuantity < 10)
                        {
                                    <span class="badge bg-warning">Low Stock</span>
                        }
                        else
                        {
                                    <span class="badge bg-success">In Stock</span>
                        }
                        </td>
                        <td><i class="bi bi-three-dots-vertical"></i></td>
                    </tr>
            }
        </tbody>
    </table>
</div>