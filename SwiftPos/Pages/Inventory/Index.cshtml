@page
@model SwiftPOS.Pages.Inventory.IndexModel
@{
    ViewData["Title"] = "Inventory";
}

<style>
    .inventory-container {
        background-color: #f8f9fa;
        min-height: 100vh;
    }

    .stats-card {
        border-radius: 15px;
        transition: 0.3s;
    }

        .stats-card:hover {
            transform: translateY(-5px);
        }

    .search-box {
        border-radius: 50px;
        padding-left: 20px;
        border: 1px solid #e0e0e0;
    }

    .product-table thead {
        background-color: #f1f3f5;
    }

    .status-pill {
        font-size: 0.75rem;
        font-weight: 600;
        padding: 5px 12px;
        border-radius: 50px;
    }
</style>

<div class="inventory-container container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center pt-4 pb-3">
        <div>
            <h4 class="fw-bold mb-0" style="color: #005f73;">Inventory Management</h4>
            <p class="text-muted small">Real-time overview of your stock and products</p>
        </div>
        <a href="/Inventory/Create" class="btn btn-primary shadow-sm rounded-pill px-4">
            <i class="bi bi-plus-lg me-1"></i> Add New Product
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stats-card p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-primary-subtle p-3 rounded-circle me-3">
                        <i class="bi bi-box-seam text-primary fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0">Total Products</h6>
                        <h4 class="fw-bold mb-0">@Model.Products.Count</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stats-card p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-warning-subtle p-3 rounded-circle me-3">
                        <i class="bi bi-exclamation-triangle text-warning fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0">Low Stock Items</h6>
                        <h4 class="fw-bold mb-0">@Model.Products.Count(p => p.StockQuantity > 0 && p.StockQuantity <= 5)</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stats-card p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-danger-subtle p-3 rounded-circle me-3">
                        <i class="bi bi-x-circle text-danger fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0">Out of Stock</h6>
                        <h4 class="fw-bold mb-0">@Model.Products.Count(p => p.StockQuantity <= 0)</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white py-3 border-0 rounded-top-4">
            <div class="d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0">Product List</h6>
                <div class="d-flex gap-2">
                    <input type="text" id="inventorySearch" class="form-control form-control-sm search-box" placeholder="Search product name..." style="width: 250px;">
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 product-table">
                    <thead>
                        <tr>
                            <th class="ps-4 py-3 text-muted small">PRODUCT INFO</th>
                            <th class="py-3 text-muted small">CATEGORY</th>
                            <th class="py-3 text-muted small">PRICE</th>
                            <th class="py-3 text-muted small text-center">QUANTITY</th>
                            <th class="py-3 text-muted small">STATUS</th>
                            <th class="text-end pe-4 py-3 text-muted small">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody id="inventoryTableBody">
                        @if (Model.Products.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <i class="bi bi-inbox fs-1 text-muted"></i>
                                    <p class="text-muted mt-2">No products found in inventory.</p>
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model.Products)
                        {
                            <tr class="product-row">
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.Name</div>
                                    <small class="text-muted">ID: @item.Id.Substring(Math.Max(0, item.Id.Length - 8))</small>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border-0 rounded-pill px-3">@item.Category</span>
                                </td>
                                <td class="fw-bold text-dark">$@item.Price.ToString("N2")</td>
                                <td class="text-center">
                                    <span class="fw-bold @(item.StockQuantity <= 5 ? "text-danger" : "text-dark")">
                                        @item.StockQuantity
                                    </span>
                                </td>
                                <td>
                                    @if (item.StockQuantity <= 0)
                                    {
                                        <span class="status-pill bg-danger-subtle text-danger border border-danger-subtle">Sold Out</span>
                                    }
                                    else if (item.StockQuantity <= 5)
                                    {
                                        <span class="status-pill bg-warning-subtle text-warning border border-warning-subtle">Low Stock</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill bg-success-subtle text-success border border-success-subtle">In Stock</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-1">
                                        <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-primary border-0 rounded-circle" title="Edit">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Are you sure you want to delete this product?');" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-light text-danger border-0 rounded-circle" title="Delete">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Simple search filter
        document.getElementById('inventorySearch').addEventListener('keyup', function () {
            let value = this.value.toLowerCase();
            let rows = document.querySelectorAll('.product-row');
            rows.forEach(row => {
                let name = row.querySelector('.fw-bold').textContent.toLowerCase();
                row.style.display = name.includes(value) ? '' : 'none';
            });
        });
    </script>
}