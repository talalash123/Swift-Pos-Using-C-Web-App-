@page "{id}"
@model SwiftPOS.Pages.Inventory.EditModel
@{
    ViewData["Title"] = "Edit Product";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4">Edit Product</h4>

                    <form method="post">
                        <input type="hidden" asp-for="Product.Id" />

                        <div class="mb-3">
                            <label class="form-label">Product Name</label>
                            <input asp-for="Product.Name" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Category</label>
                            <select asp-for="Product.Category" class="form-select" required>
                                <option value="Food">Food</option>
                                <option value="Electronic">Electronic</option>
                                <option value="Crockery">Crockery</option>
                                <option value="Grocery">Grocery</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Price ($)</label>
                            <input asp-for="Product.Price" type="number" step="0.01" class="form-control" required />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold">Update Changes</button>
                            <a asp-page="./Index" class="btn btn-light border w-100 rounded-pill py-2 fw-bold">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>