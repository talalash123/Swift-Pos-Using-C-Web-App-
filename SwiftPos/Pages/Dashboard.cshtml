@page
@model SwiftPOS.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard Overview";
}

<style>
    :root {
        --pos-primary: #004654; /* Darker teal for better contrast */
        --pos-secondary: #0a9396;
        --pos-accent: #94d2bd;
        --pos-bg: #f4f7f6;
        --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        --glass-bg: rgba(255, 255, 255, 0.95);
    }

    body {
        background-color: var(--pos-bg);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        color: #2d3436;
    }

    /* Page Heading Enhancement */
    h3.fw-bold {
        letter-spacing: -0.5px;
        color: var(--pos-primary);
    }

    /* Modern Stats Cards */
    .stat-card {
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 20px;
        box-shadow: var(--card-shadow);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        background: var(--glass-bg);
        position: relative;
        z-index: 1;
    }

        .stat-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
            border-color: var(--pos-secondary);
        }

    /* Icon Background Gradients */
    .stat-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        transition: all 0.3s ease;
    }

    .stat-card:hover .stat-icon {
        transform: scale(1.1) rotate(-5deg);
    }

    /* Content Box (Charts/Tables) */
    .content-box {
        background: #fff;
        border-radius: 24px;
        padding: 28px;
        box-shadow: var(--card-shadow);
        border: 1px solid rgba(0,0,0,0.02);
        height: 100%;
    }

    /* Table Styling */
    .table-container {
        border-radius: 16px;
        overflow: hidden;
    }

    .table thead th {
        background-color: #fcfdfe;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 1px;
        font-weight: 800;
        color: #a0aec0;
        border-bottom: 2px solid #f7fafc;
        padding: 20px 15px;
    }

    .table tbody td {
        padding: 18px 15px;
        vertical-align: middle;
        font-size: 0.9rem;
        border-bottom: 1px solid #f7fafc;
        transition: background 0.2s;
    }

    .table tbody tr:hover td {
        background-color: #fbfcfd;
    }

    .live-dot {
        height: 8px;
        width: 8px;
        background-color: #2ec4b6;
        border-radius: 50%;
        display: inline-block;
        animation: blink 1.5s infinite;
    }

    @@keyframes blink {
        0% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.4;
            transform: scale(1.2);
        }

        100% {
            opacity: 1;
            transform: scale(1);
        }
    /* New Soft Color Palette */
    .bg-soft-teal {
        background: linear-gradient(135deg, #e6f7f8 0%, #b2e2e5 100%);
        color: #005f73;
    }

    .bg-soft-green {
        background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
        color: #1b5e20;
    }

    .bg-soft-orange {
        background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
        color: #e65100;
    }

    .bg-soft-purple {
        background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
        color: #4a148c;
    }

    /* Custom Scrollbar */
    ::-webkit-scrollbar {
        width: 6px;
    }

    ::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    ::-webkit-scrollbar-thumb {
        background: #cbd5e0;
        border-radius: 10px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }
</style>

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center py-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Dashboard Overview</h3>
            <p class="text-muted small mb-0">Track your store's real-time performance</p>
        </div>
        <div>
            <button class="btn btn-white shadow-sm border-0 rounded-3 px-3 fw-bold small">
                <i class="bi bi-download me-2"></i> Export Report
            </button>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small fw-bold mb-1">TOTAL ORDERS</p>
                        <h2 class="fw-bold mb-0">@Model.TotalOrders</h2>
                    </div>
                    <div class="stat-icon bg-soft-teal">
                        <i class="bi bi-cart-check"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small fw-bold mb-1">REVENUE</p>
                        <h2 class="fw-bold mb-0">$@Model.Revenue.ToString("N2")</h2>
                    </div>
                    <div class="stat-icon bg-soft-green">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small fw-bold mb-1">AVG ORDER</p>
                        <h2 class="fw-bold mb-0">$@((Model.TotalOrders > 0 ? Model.Revenue / Model.TotalOrders : 0).ToString("N2"))</h2>
                    </div>
                    <div class="stat-icon bg-soft-orange">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small fw-bold mb-1">PRODUCTS</p>
                        <h2 class="fw-bold mb-0">@Model.ActiveProductsCount</h2>
                    </div>
                    <div class="stat-icon bg-soft-purple">
                        <i class="bi bi-box-seam"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="content-box">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h6 class="fw-bold mb-0">Sales Analytics (Weekly)</h6>
                    <div class="badge bg-light text-dark border fw-normal px-2 py-1 small">Real-time</div>
                </div>
                <div style="height: 300px;">
                    <canvas id="salesTrendChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="content-box text-center">
                <h6 class="fw-bold mb-4">Stock Overview</h6>
                <div style="height: 250px;">
                    <canvas id="stockDoughnutChart"></canvas>
                </div>
                <div class="mt-4 d-flex justify-content-around small">
                    <div><i class="bi bi-circle-fill text-primary me-1"></i> In Stock</div>
                    <div><i class="bi bi-circle-fill text-warning me-1"></i> Low</div>
                    <div><i class="bi bi-circle-fill text-danger me-1"></i> Out</div>
                </div>
            </div>
        </div>
    </div>

    <div class="content-box mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h6 class="fw-bold mb-0">Recent Transactions</h6>
            <a href="/SalesHistory" class="btn btn-sm btn-outline-primary border-0 fw-bold">View All History <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Amount</th>
                        <th>Time</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentTransactions.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted small">
                                No transactions recorded yet. Start billing in the terminal!
                            </td>
                        </tr>
                    }
                    @foreach (var order in Model.RecentTransactions)
                    {
                        <tr>
                            <td class="fw-bold">#TRX-@(order.Id?.Substring(Math.Max(0, order.Id.Length - 8)))</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded-circle p-2 me-2" style="width:32px; height:32px; display:flex; align-items:center; justify-content:center; font-size:10px;">
                                        <i class="bi bi-person"></i>
                                    </div>
                                    @order.CustomerName
                                </div>
                            </td>
                            <td class="fw-bold">$@order.GrandTotal.ToString("N2")</td>
                            <td class="text-muted small">@order.OrderDate.ToLocalTime().ToString("hh:mm tt")</td>
                            <td><span class="badge bg-soft-green badge-status">COMPLETED</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // 1. DATA FROM SERVER (For Sales Chart)
        const chartLabels = @Html.Raw(Json.Serialize(Model.ChartLabels));
        const chartValues = @Html.Raw(Json.Serialize(Model.ChartData));

        // 2. INITIALIZE SALES BAR CHART (Server-side data)
        const salesCtx = document.getElementById('salesTrendChart').getContext('2d');
        const salesChart = new Chart(salesCtx, {
            type: 'bar',
            data: {
                labels: chartLabels,
                datasets: [{
                    label: 'Daily Sales',
                    data: chartValues,
                    backgroundColor: (ctx) => ctx.index === 6 ? '#005f73' : '#d1e3e7',
                    borderRadius: 8,
                    barThickness: 35
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#f0f0f0' }, border: { display: false } },
                    x: { grid: { display: false }, border: { display: false } }
                }
            }
        });

        // 3. INITIALIZE STOCK DOUGHNUT CHART (Empty first, then live update)
        const stockCtx = document.getElementById('stockDoughnutChart').getContext('2d');
        let stockChart = new Chart(stockCtx, {
            type: 'doughnut',
            data: {
                labels: ['In Stock', 'Low Stock', 'Out of Stock'],
                datasets: [{
                    data: [0, 0, 0],
                    backgroundColor: ['#005f73', '#ee9b00', '#ae2012'],
                    borderWidth: 0,
                    cutout: '75%'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } }
            }
        });

        // 4. REAL-TIME REFRESH FUNCTION
        async function refreshDashboardData() {
            try {
                // Fetch Stock Data
                const stockRes = await fetch('/Dashboard?handler=StockData');
                if (stockRes.ok) {
                    const stockData = await stockRes.json();
                    stockChart.data.datasets[0].data = stockData;
                    stockChart.update('none');
                }

                // Fetch Recent Transactions
                const transRes = await fetch('/Dashboard?handler=RecentTransactions');
                if (transRes.ok) {
                    const transactions = await transRes.json();
                    updateTransactionTable(transactions);
                }
            } catch (err) {
                console.error("Real-time sync error:", err);
            }
        }

        // Helper to update the table HTML
        function updateTransactionTable(data) {
            const tbody = document.querySelector('table tbody');
            if (!tbody || data.length === 0) return;

            let html = '';
            data.forEach(tr => {
                html += `
                            <tr>
                                <td class="fw-bold">#TRX-${tr.id}</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light rounded-circle p-2 me-2" style="width:32px; height:32px; display:flex; align-items:center; justify-content:center; font-size:10px;">
                                            <i class="bi bi-person"></i>
                                        </div>
                                        ${tr.customerName}
                                    </div>
                                </td>
                                <td class="fw-bold">$${tr.total}</td>
                                <td class="text-muted small">${tr.time}</td>
                                <td><span class="badge bg-soft-green badge-status">COMPLETED</span></td>
                            </tr>`;
            });
            tbody.innerHTML = html;
        }

        // 5. START TIMERS
        setInterval(refreshDashboardData, 5000); // Har 5 second baad refresh
        refreshDashboardData(); // Foran load hone par refresh
    </script>
}